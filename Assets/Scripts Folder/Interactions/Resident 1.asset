  m_Script: {fileID: 11500000, guid: 268bf36e2c95048f4b4ca0fcdf827688, type: 3}
  m_Name: Resident 1
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  SpeakerName: Dialogue
  lines:
  - Excuse me sir, I have a problem with the heat in my house.
  - Everytime we try to crank the heat up it shuts off soon after.
  - It gets pretty cold in this building, can you figure out the issue. The furnace
    is located in the basement area, so it should be easy to spot.
